# Secrets agent backend: bitwarden | 1password | mock
SECRETS_AGENT_BACKEND=mock

# Required for rotate-plan and rotate-exec confirmation token generation.
# Use a long random value; never commit real values.
SECRETS_AGENT_CONFIRM_SALT=replace-me-with-random-string

# Metadata-only audit log path.
SECRETS_AGENT_LOG_PATH=logs/secrets_agent_audit.log

# Optional integration hooks. {item_id} is replaced at runtime.
SECRETS_AGENT_ROTATE_HOOK=
SECRETS_AGENT_REVOKE_HOOK=

# Ecosystem intelligence agent email delivery (optional).
# Gmail SMTP: smtp.gmail.com | Yahoo SMTP: smtp.mail.yahoo.com
EI_SMTP_HOST=
EI_SMTP_PORT=587
EI_SMTP_USER=
EI_SMTP_PASS=
EI_SMTP_FROM=
